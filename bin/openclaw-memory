#!/usr/bin/env bash
# OpenClaw Memory Stack — CLI Entry Point
# Usage: openclaw-memory "<query>" [--hint <hint>] [--backend <name>] [--json]
#        openclaw-memory health [--deep]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
INSTALL_ROOT="${OPENCLAW_INSTALL_ROOT:-$HOME/.openclaw/memory-stack}"
ROUTER="$INSTALL_ROOT/skills/memory-router/router.sh"

# Version
VERSION="0.1.4"

# Source libraries
source "$INSTALL_ROOT/lib/platform.sh"
source "$INSTALL_ROOT/lib/license.sh"

# ── --help and --version: never need license ───────────────────────
case "${1:-}" in
  --version|-v) echo "openclaw-memory v$VERSION"; exit 0 ;;
  --help|-h)
    cat <<HELPEOF
OpenClaw Memory Stack v$VERSION

Usage:
  openclaw-memory "<query>" [options]    Search across memory backends
  openclaw-memory health [--deep]        Check all backend health status

Options:
  --hint <hint>       Routing hint: exact, semantic, timeline
  --backend <name>    Direct to specific backend (skip router)
  --json              Force JSON output
  --version, -v       Show version
  --help, -h          Show this help

Direct backend access:
  openclaw-memory --backend <name> search "query"
  openclaw-memory --backend <name> store slug "content"

Backends: $(ls -d "$INSTALL_ROOT/skills/memory-"*/wrapper.sh 2>/dev/null | sed 's|.*/memory-||;s|/wrapper.sh||' | grep -v router | paste -sd ',' - | sed 's/,/, /g')
HELPEOF
    exit 0
    ;;
esac

# ── health: no license required ────────────────────────────────────
if [ "${1:-}" = "health" ]; then
  shift
  DEEP_FLAG=""
  [[ "${1:-}" == "--deep" ]] && DEEP_FLAG="--deep"
  echo "OpenClaw Memory Stack — Backend Health"
  echo ""
  printf "  %-15s %-12s %s\n" "BACKEND" "STATUS" "REASON"
  printf "  %-15s %-12s %s\n" "-------" "------" "------"
  for skill_dir in "$INSTALL_ROOT/skills/memory-"*; do
    [ -f "$skill_dir/wrapper.sh" ] || continue
    backend_name=$(basename "$skill_dir" | sed 's/memory-//')
    [ "$backend_name" = "router" ] && continue
    health_json=$(OPENCLAW_INSTALL_ROOT="$INSTALL_ROOT" bash "$skill_dir/wrapper.sh" health $DEEP_FLAG 2>/dev/null) || health_json='{"status":"error","reason":"wrapper failed"}'
    bstatus=$(echo "$health_json" | python3 -c "import json,sys; print(json.load(sys.stdin).get('status','error'))" 2>/dev/null || echo "error")
    reason=$(echo "$health_json" | python3 -c "import json,sys; print(json.load(sys.stdin).get('reason',''))" 2>/dev/null || echo "")
    printf "  %-15s %-12s %s\n" "$backend_name" "$bstatus" "$reason"
  done
  echo ""
  exit 0
fi

# ── Parse remaining arguments ─────────────────────────────────────
QUERY="" HINT="" BACKEND="" JSON_OUTPUT=false NATIVE_CMD=""
while [ $# -gt 0 ]; do
  case "$1" in
    --hint) HINT="$2"; shift 2 ;;
    --backend) BACKEND="$2"; shift 2 ;;
    --json) JSON_OUTPUT=true; shift ;;
    *)
      if [ -z "$QUERY" ]; then
        QUERY="$1"
      else
        NATIVE_CMD="$NATIVE_CMD $1"
      fi
      shift
      ;;
  esac
done

# ── Direct backend access: full license check ─────────────────────
if [ -n "$BACKEND" ]; then
  require_licensed

  WRAPPER="$INSTALL_ROOT/skills/memory-${BACKEND}/wrapper.sh"
  if [ ! -x "$WRAPPER" ]; then
    echo "Error: backend '$BACKEND' not found at $WRAPPER" >&2
    exit 1
  fi

  if [ -n "$QUERY" ]; then
    exec bash "$WRAPPER" "$QUERY" $NATIVE_CMD
  else
    echo "Error: no command specified for backend '$BACKEND'" >&2
    exit 1
  fi
fi

# ── Router dispatch: full license check ───────────────────────────
if [ -z "$QUERY" ]; then
  echo "Error: no query provided. Use --help for usage." >&2
  exit 1
fi

require_licensed

ROUTER_ARGS=("$QUERY")
[ -n "$HINT" ] && ROUTER_ARGS+=(--hint "$HINT")
ROUTER_ARGS+=(--backends-json "$HOME/.openclaw/state/backends.json")

exec bash "$ROUTER" "${ROUTER_ARGS[@]}"
