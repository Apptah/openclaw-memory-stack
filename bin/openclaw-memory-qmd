#!/usr/bin/env bash
# OpenClaw Memory Stack — qmd-compatible shim
# Drop-in replacement for `qmd` CLI that OpenClaw's memory system calls.
#
# Usage (set in openclaw.json):
#   "memory": { "backend": "qmd", "qmd": { "command": "openclaw-memory-qmd" } }
#
# Translates qmd subcommands → openclaw-memory router calls,
# and converts router JSON output → QmdQueryResult[] format.
set -euo pipefail

INSTALL_ROOT="${OPENCLAW_INSTALL_ROOT:-$HOME/.openclaw/memory-stack}"
ROUTER="$INSTALL_ROOT/skills/memory-router/router.sh"
QMD_BIN="${OPENCLAW_QMD_FALLBACK:-qmd}"

# ── Helpers ──────────────────────────────────────────────────
has_python3() { command -v python3 &>/dev/null; }

# Convert router envelope JSON → QmdQueryResult[] array
# Input:  { "results": [{"content":"...","relevance":0.8,"source":"..."}], ... }
# Output: [{"docid":"...","score":0.8,"file":"...","snippet":"..."}]
router_to_qmd() {
  python3 -c "
import json, sys, hashlib

raw = sys.stdin.read().strip()
if not raw:
    print('[]')
    sys.exit(0)

try:
    envelope = json.loads(raw)
except json.JSONDecodeError:
    print('[]')
    sys.exit(0)

results = envelope.get('results', [])
if not results:
    print('[]')
    sys.exit(0)

out = []
for r in results:
    content = r.get('content', '')
    source = r.get('source', '')
    score = r.get('relevance', 0.0)
    docid = '#' + hashlib.md5(content[:200].encode()).hexdigest()[:6]

    out.append({
        'docid': docid,
        'score': float(score),
        'file': source,
        'snippet': content[:700],
        'body': content,
        'collection': envelope.get('routed_to', '')
    })

json.dump(out, sys.stdout)
"
}

# ── Subcommand dispatch ──────────────────────────────────────
CMD="${1:-}"
shift 2>/dev/null || true

case "$CMD" in

  # ── Search commands: route through memory-stack ──────────
  search|vsearch|query)
    QUERY="" LIMIT=6 JSON_FLAG=false COLLECTIONS=()
    while [ $# -gt 0 ]; do
      case "$1" in
        --json) JSON_FLAG=true; shift ;;
        -n)     LIMIT="$2"; shift 2 ;;
        -c)     COLLECTIONS+=("$2"); shift 2 ;;
        *)      [ -z "$QUERY" ] && QUERY="$1" || true; shift ;;
      esac
    done

    if [ -z "$QUERY" ]; then
      echo "No results found." >&2
      exit 0
    fi

    # Map qmd search mode → router hint
    HINT=""
    case "$CMD" in
      search)  HINT="exact" ;;
      vsearch) HINT="semantic" ;;
      query)   HINT="" ;;  # let router auto-detect
    esac

    ROUTER_ARGS=("$QUERY")
    [ -n "$HINT" ] && ROUTER_ARGS+=(--hint "$HINT")

    # Run router, convert output
    ROUTER_OUTPUT=$(bash "$ROUTER" "${ROUTER_ARGS[@]}" 2>/dev/null) || ROUTER_OUTPUT=""

    if [ "$JSON_FLAG" = true ] && has_python3; then
      echo "$ROUTER_OUTPUT" | router_to_qmd
    else
      # Plain text fallback
      if has_python3; then
        echo "$ROUTER_OUTPUT" | python3 -c "
import json, sys
raw = sys.stdin.read().strip()
if not raw:
    print('No results found.')
    sys.exit(0)
try:
    d = json.loads(raw)
    for r in d.get('results', []):
        print(f\"[{r.get('relevance',0):.2f}] {r.get('source','')}\")
        print(f\"  {r.get('content','')[:200]}\")
        print()
except:
    print(raw)
"
      else
        echo "$ROUTER_OUTPUT"
      fi
    fi
    ;;

  # ── Collection management: pass through to real qmd ─────
  collection)
    SUBCMD="${1:-}"
    shift 2>/dev/null || true
    if command -v "$QMD_BIN" &>/dev/null; then
      exec "$QMD_BIN" collection "$SUBCMD" "$@"
    else
      # Stub responses for when qmd is not installed
      case "$SUBCMD" in
        list)
          if [[ " $* " == *"--json"* ]]; then
            echo "[]"
          else
            echo "No collections (qmd not installed, using memory-stack router)"
          fi
          ;;
        add|remove)
          echo "Collection operation skipped (qmd not installed, memory-stack manages backends)" >&2
          exit 0
          ;;
        *) echo "Unknown collection subcommand: $SUBCMD" >&2; exit 1 ;;
      esac
    fi
    ;;

  # ── Update/embed: pass through to real qmd or no-op ────
  update)
    if command -v "$QMD_BIN" &>/dev/null; then
      exec "$QMD_BIN" update "$@"
    else
      exit 0  # silent no-op
    fi
    ;;

  embed)
    if command -v "$QMD_BIN" &>/dev/null; then
      exec "$QMD_BIN" embed "$@"
    else
      exit 0  # silent no-op
    fi
    ;;

  # ── Status ─────────────────────────────────────────────
  status)
    if command -v "$QMD_BIN" &>/dev/null; then
      exec "$QMD_BIN" status "$@"
    else
      echo "openclaw-memory-qmd shim (qmd not installed, using memory-stack router)"
      exit 0
    fi
    ;;

  # ── MCP server mode: pass through ─────────────────────
  mcp)
    if command -v "$QMD_BIN" &>/dev/null; then
      exec "$QMD_BIN" mcp "$@"
    else
      echo "MCP mode requires qmd binary" >&2
      exit 1
    fi
    ;;

  # ── Fallback: pass unknown commands to real qmd ────────
  *)
    if command -v "$QMD_BIN" &>/dev/null; then
      exec "$QMD_BIN" "$CMD" "$@"
    else
      echo "Unknown command: $CMD" >&2
      exit 1
    fi
    ;;
esac
