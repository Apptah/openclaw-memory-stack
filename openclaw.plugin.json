{
  "id": "openclaw-memory-stack",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "routerMode": {
        "type": "string",
        "enum": ["auto", "qmd-only", "totalrecall-only"]
      },
      "searchMode": {
        "type": "string",
        "enum": ["bm25", "vector", "hybrid"]
      },
      "autoRecall": {
        "type": "boolean"
      },
      "autoCapture": {
        "type": "boolean"
      },
      "maxRecallResults": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20
      },
      "maxRecallTokens": {
        "type": "integer",
        "minimum": 100,
        "maximum": 5000
      }
    }
  },
  "uiHints": {
    "autoRecall": {
      "label": "Auto Recall",
      "help": "Inject relevant memories before each agent turn"
    },
    "autoCapture": {
      "label": "Auto Capture",
      "help": "Store conversation context after each turn"
    },
    "maxRecallTokens": {
      "label": "Recall Token Budget",
      "help": "Maximum tokens used for injected memories per turn"
    }
  }
}
