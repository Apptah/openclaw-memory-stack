{
  "id": "openclaw-memory-stack",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "routerMode": {
        "type": "string",
        "enum": ["auto", "qmd-only", "totalrecall-only"]
      },
      "searchMode": {
        "type": "string",
        "enum": ["bm25", "vector", "hybrid"]
      },
      "autoRecall": {
        "type": "boolean"
      },
      "autoCapture": {
        "type": "boolean"
      },
      "maxRecallResults": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20
      },
      "maxRecallTokens": {
        "type": "integer",
        "minimum": 100,
        "maximum": 5000
      },
      "mmrLambda": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "halfLifeDays": {
        "type": "integer",
        "minimum": 1
      },
      "graphEnabled": {
        "type": "boolean"
      },
      "sessionSearch": {
        "type": "boolean"
      },
      "llmEndpoint": {
        "type": "string",
        "default": "https://api.openai.com/v1"
      },
      "llmModel": {
        "type": "string",
        "default": "gpt-4o-mini"
      },
      "llmApiKey": {
        "type": "string"
      },
      "autoOrganize": {
        "type": "boolean",
        "default": false
      },
      "losslessEnabled": {
        "type": "boolean",
        "default": true
      },
      "graphDepth": {
        "type": "integer",
        "minimum": 1,
        "maximum": 5,
        "default": 2
      },
      "graphMaxNodes": {
        "type": "integer",
        "minimum": 10,
        "maximum": 200,
        "default": 50
      },
      "autoRecallTier": {
        "type": "string",
        "enum": ["L0", "L1", "L2"],
        "default": "L0"
      },
      "toolResponseTier": {
        "type": "string",
        "enum": ["L1", "L2"],
        "default": "L1"
      },
      "qmdCollection": {
        "type": "string"
      },
      "qmdProbeQuery": {
        "type": "string"
      },
      "qmdMode": {
        "type": "string",
        "enum": ["auto", "search", "vsearch", "query"],
        "default": "auto"
      }
    }
  },
  "uiHints": {
    "autoRecall": {
      "label": "Auto Recall",
      "help": "Inject relevant memories before each agent turn"
    },
    "autoCapture": {
      "label": "Auto Capture",
      "help": "Store conversation context after each turn"
    },
    "maxRecallTokens": {
      "label": "Recall Token Budget",
      "help": "Maximum tokens used for injected memories per turn"
    },
    "autoRecallTier": {
      "label": "Auto-Recall Tier",
      "help": "L0 (~100 tokens), L1 (~800 tokens), L2 (~2000 tokens, full content)"
    },
    "toolResponseTier": {
      "label": "Search Response Tier",
      "help": "L1 (summary) or L2 (full content). Use --full suffix for one-off L2."
    },
    "qmdCollection": {
      "label": "QMD Collection",
      "help": "QMD collection name for scoped search. Auto-detected from .openclaw-memory.json if empty."
    },
    "qmdProbeQuery": {
      "label": "QMD Probe Query",
      "help": "Fixed query for runtime probe. Required to enable vsearch/query modes."
    }
  }
}
