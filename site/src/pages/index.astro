---
import Layout from "../layouts/Layout.astro";
---
<Layout title="OpenClaw Memory Stack">
  <style>
    /* ── Nav ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 2rem;
      background: rgba(6, 8, 12, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      font-family: var(--font-mono);
      font-weight: 700;
      font-size: 0.95rem;
      color: var(--accent);
      letter-spacing: -0.02em;
    }
    .nav-logo span { color: var(--muted); }
    .nav-claw-icon { vertical-align: -4px; margin-right: 4px; }
    .nav-links { display: flex; gap: 1.5rem; align-items: center; }
    .nav-links a { color: var(--muted); font-size: 0.85rem; font-weight: 500; }
    .nav-links a:hover { color: var(--fg-bright); text-shadow: none; }

    /* ── Hero ── */
    .hero {
      max-width: 900px;
      margin: 0 auto;
      padding: 10rem 2rem 5rem;
      text-align: center;
      position: relative;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -60%);
      width: 600px; height: 600px;
      background: radial-gradient(circle, var(--accent-dim) 0%, transparent 70%);
      pointer-events: none;
      z-index: -1;
    }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--accent);
      background: var(--accent-dim);
      border: 1px solid var(--border-bright);
      border-radius: 999px;
      padding: 0.35rem 1rem;
      margin-bottom: 2rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .badge::before { content: '//'; color: var(--muted); }
    .hero h1 {
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 1.5rem;
      letter-spacing: -0.03em;
      color: var(--fg-bright);
    }
    .hero h1 .glow {
      color: var(--accent);
      text-shadow: 0 0 40px var(--accent-glow);
    }
    .hero .subtitle {
      font-size: 1.15rem;
      color: var(--muted);
      max-width: 560px;
      margin: 0 auto 3rem;
      line-height: 1.7;
    }
    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      background: var(--accent);
      color: var(--bg);
      font-weight: 700;
      padding: 0.85rem 2.2rem;
      border-radius: 8px;
      font-size: 1rem;
      border: none;
      cursor: pointer;
      transition: all 0.25s;
      text-decoration: none;
      font-family: var(--font-sans);
    }
    .hero-cta:hover {
      background: var(--accent-hover);
      color: var(--bg);
      text-shadow: none;
      box-shadow: 0 0 30px var(--accent-glow);
      transform: translateY(-1px);
    }
    .hero-price {
      display: block;
      margin-top: 1rem;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--muted);
    }

    /* ── Terminal demo ── */
    .terminal-wrap {
      max-width: 700px;
      margin: 0 auto 6rem;
      padding: 0 2rem;
    }
    .terminal {
      background: var(--surface);
      border: 1px solid var(--border-bright);
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 0 40px rgba(0, 229, 255, 0.05);
    }
    .terminal-bar {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 0.75rem 1rem;
      background: var(--surface-elevated);
      border-bottom: 1px solid var(--border);
    }
    .terminal-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--border-bright);
    }
    .terminal-dot:nth-child(1) { background: #ff5f57; }
    .terminal-dot:nth-child(2) { background: #ffbd2e; }
    .terminal-dot:nth-child(3) { background: #28c840; }
    .terminal-title {
      flex: 1;
      text-align: center;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--muted);
      margin-right: 40px;
    }
    .terminal-body {
      padding: 1.25rem 1.5rem;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      line-height: 1.8;
      overflow-x: auto;
    }
    .terminal-body .prompt { color: var(--accent); }
    .terminal-body .cmd { color: var(--fg-bright); }
    .terminal-body .comment { color: var(--muted); font-style: italic; }
    .terminal-body .output { color: var(--muted); }
    .terminal-body .success { color: var(--green); }

    /* ── Section titles ── */
    .section {
      max-width: 900px;
      margin: 0 auto;
      padding: 4rem 2rem;
    }
    .section-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--accent);
      margin-bottom: 0.75rem;
    }
    .section h2 {
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--fg-bright);
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
    }
    .section .section-desc {
      color: var(--muted);
      max-width: 500px;
      margin-bottom: 2.5rem;
    }

    /* ── Feature cards ── */
    .features {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1rem;
    }
    .feature-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.75rem;
      transition: all 0.3s;
    }
    .feature-card:hover {
      border-color: var(--border-bright);
      box-shadow: 0 0 20px rgba(0, 229, 255, 0.05);
      transform: translateY(-2px);
    }
    .feature-icon {
      width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      background: var(--accent-dim);
      border-radius: 8px;
      margin-bottom: 1rem;
      font-size: 1rem;
    }
    .feature-card h3 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--fg-bright);
      margin-bottom: 0.5rem;
      font-family: var(--font-mono);
    }
    .feature-card p {
      font-size: 0.88rem;
      color: var(--muted);
      line-height: 1.6;
    }

    /* ── Routing flow ── */
    .routing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 0.75rem;
    }
    .route-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem 1.25rem;
      font-size: 0.85rem;
      overflow: hidden;
      word-break: break-word;
    }
    .route-label {
      color: var(--fg-bright);
      font-weight: 500;
      font-size: 0.82rem;
    }
    .route-arrow {
      color: var(--accent);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      white-space: nowrap;
    }
    .route-target {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--muted);
    }

    /* ── Compare stats ── */
    .compare-header-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-bottom: 3rem;
    }
    .compare-stat {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.5rem;
      text-align: center;
    }
    .compare-stat-number {
      font-family: var(--font-mono);
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--accent);
      line-height: 1;
      margin-bottom: 0.5rem;
    }
    .compare-stat-label {
      font-size: 0.82rem;
      color: var(--fg-bright);
      line-height: 1.4;
    }
    .compare-stat-label span {
      color: var(--muted);
      font-size: 0.75rem;
    }

    /* ── Compare table ── */
    .compare-table-wrap {
      overflow-x: auto;
      margin: 0 -0.5rem;
    }
    .compare-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
    }
    .compare-table th {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent);
      text-align: left;
      padding: 0.75rem 1rem;
      border-bottom: 2px solid var(--border-bright);
    }
    .compare-table th:not(:first-child) {
      text-align: center;
      width: 35%;
    }
    .compare-table td {
      padding: 0.75rem 1rem;
      border-bottom: 1px solid var(--border);
      color: var(--fg);
      vertical-align: top;
      line-height: 1.5;
    }
    .compare-table td:not(:first-child) {
      text-align: left;
    }
    .compare-table td:first-child {
      font-weight: 500;
      color: var(--fg-bright);
      width: 30%;
    }
    .compare-table tr:hover {
      background: rgba(0, 229, 255, 0.03);
    }
    .compare-table td.yes {
      color: #28c840;
    }
    .compare-table td.no {
      color: var(--muted);
    }
    .compare-table td.partial {
      color: #ffbd2e;
    }
    .compare-group td {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--accent);
      padding: 1.5rem 1rem 0.5rem;
      border-bottom: 1px solid var(--border-bright);
      font-weight: 700;
    }
    @media (max-width: 640px) {
      .compare-header-cards {
        grid-template-columns: 1fr;
      }
    }

    /* ── CTA ── */
    .cta-section {
      max-width: 900px;
      margin: 0 auto;
      padding: 4rem 2rem;
    }
    .cta-box {
      text-align: center;
      padding: 4rem 2rem;
      background: var(--surface);
      border: 1px solid var(--border-bright);
      border-radius: 16px;
      position: relative;
      overflow: hidden;
    }
    .cta-box::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at top, var(--accent-dim) 0%, transparent 60%);
      pointer-events: none;
    }
    .cta-box .price {
      font-size: 3.5rem;
      font-weight: 800;
      color: var(--fg-bright);
      margin-bottom: 0.25rem;
      position: relative;
      font-family: var(--font-mono);
    }
    .cta-box .price-note {
      color: var(--muted);
      margin-bottom: 2rem;
      font-size: 0.9rem;
      position: relative;
    }
    .cta-box .cta-btn-wrap { position: relative; }

    /* ── Disclaimers ── */
    .disclaimers-section {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 2rem 4rem;
    }
    .disclaimers {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 0.75rem;
      list-style: none;
    }
    .disclaimers li {
      font-size: 0.82rem;
      color: var(--muted);
      padding: 0.85rem 1rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      line-height: 1.5;
    }
    .disclaimers li strong {
      color: var(--fg);
      font-weight: 600;
    }

    /* ── FAQ ── */
    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .faq-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      transition: border-color 0.2s;
    }
    .faq-item[open] {
      border-color: var(--border-bright);
    }
    .faq-item summary {
      padding: 1rem 1.25rem;
      cursor: pointer;
      font-weight: 600;
      color: var(--fg-bright);
      font-size: 0.92rem;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .faq-item summary::after {
      content: '+';
      font-family: var(--font-mono);
      color: var(--accent);
      font-size: 1.1rem;
      transition: transform 0.2s;
    }
    .faq-item[open] summary::after {
      transform: rotate(45deg);
    }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item p {
      padding: 0 1.25rem 1rem;
      font-size: 0.88rem;
      color: var(--muted);
      line-height: 1.7;
    }
    .faq-item strong {
      color: var(--fg);
    }

    /* ── Footer ── */
    footer {
      text-align: center;
      padding: 3rem 2rem;
      color: var(--muted);
      font-size: 0.8rem;
      border-top: 1px solid var(--border);
      font-family: var(--font-mono);
    }
    footer .links { display: flex; gap: 1.5rem; justify-content: center; margin-top: 0.75rem; }
    footer .links a { color: var(--muted); font-size: 0.75rem; }

    /* ── Responsive ── */
    @media (max-width: 640px) {
      nav { padding: 0.75rem 1rem; }
      .hero { padding: 8rem 1.25rem 3rem; }
      .section { padding: 3rem 1.25rem; }
      .terminal-wrap { padding: 0 1.25rem; }
      .cta-section { padding: 3rem 1.25rem; }
    }
  </style>

  <nav>
    <div class="nav-logo">
      <svg class="nav-claw-icon" width="24" height="24" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs><linearGradient id="lg" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#ff4d4d"/><stop offset="100%" stop-color="#991b1b"/></linearGradient></defs>
        <path d="M60 10 C30 10 15 35 15 55 C15 75 30 95 45 100 L45 110 L55 110 L55 100 C55 100 60 102 65 100 L65 110 L75 110 L75 100 C90 95 105 75 105 55 C105 35 90 10 60 10Z" fill="url(#lg)"/>
        <path d="M20 45 C5 40 0 50 5 60 C10 70 20 65 25 55 C28 48 25 45 20 45Z" fill="url(#lg)"/>
        <path d="M100 45 C115 40 120 50 115 60 C110 70 100 65 95 55 C92 48 95 45 100 45Z" fill="url(#lg)"/>
        <path d="M45 15 Q35 5 30 8" stroke="#ff4d4d" stroke-width="3" stroke-linecap="round"/>
        <path d="M75 15 Q85 5 90 8" stroke="#ff4d4d" stroke-width="3" stroke-linecap="round"/>
        <circle cx="45" cy="35" r="6" fill="#050810"/><circle cx="75" cy="35" r="6" fill="#050810"/>
        <circle cx="46" cy="34" r="2.5" fill="#00e5cc"/><circle cx="76" cy="34" r="2.5" fill="#00e5cc"/>
      </svg>
      openclaw<span>/memory-stack</span>
    </div>
    <div class="nav-links">
      <a href="#features">Features</a>
      <a href="#compare">vs Native</a>
      <a href="#faq">FAQ</a>
      <a href="/manage">Manage License</a>
    </div>
  </nav>

  <div class="hero">
    <div class="badge">v2 — Official OpenClaw Plugin</div>
    <h1>Remember more.<br/><span class="glow">Spend less.</span></h1>
    <p class="subtitle">
      Your <strong>OpenClaw</strong> agent forgets old decisions and wastes tokens re-reading the same context.
      Memory Stack fixes both — smarter memory that uses up to 90% fewer tokens per search.
      Your agent remembers everything. Your API bill stays low.
    </p>
    <button class="hero-cta" id="buy-btn">
      Get Memory Stack
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <span class="hero-price">$49 &mdash; one-time purchase, no subscription</span>
  </div>

  <div class="terminal-wrap">
    <div class="terminal">
      <div class="terminal-bar">
        <div class="terminal-dot"></div>
        <div class="terminal-dot"></div>
        <div class="terminal-dot"></div>
        <div class="terminal-title">openclaw-memory</div>
      </div>
      <div class="terminal-body">
        <div><span class="comment"># Install — one command, done</span></div>
        <div><span class="prompt">$</span> <span class="cmd">./install.sh --key=oc-starter-xxxxxxxxxxxx</span></div>
        <div><span class="success">  [OK]  License verified</span></div>
        <div><span class="success">  [OK]  Registered as OpenClaw memory plugin</span></div>
        <div>&nbsp;</div>
        <div><span class="comment"># Restart OpenClaw — memory is now active</span></div>
        <div><span class="prompt">$</span> <span class="cmd">openclaw gateway restart</span></div>
        <div><span class="success">  [OK]  Memory Stack v2 registered (engines: fts5+qmd+rescue+graph)</span></div>
        <div>&nbsp;</div>
        <div><span class="comment"># Just talk — memory works in the background</span></div>
        <div><span class="output">  You: What did we decide about the API design?</span></div>
        <div><span class="success">  [memory] 6 engines searched, 4 results merged (RRF fusion)</span></div>
        <div><span class="output">  Agent: We decided to use REST with /api/v2/...</span></div>
      </div>
    </div>
  </div>

  <div class="section" id="features">
    <div class="section-label">// why memory stack</div>
    <h2>Better memory. Lower bills.</h2>
    <p class="section-desc">Every wasted token is money out of your pocket. Memory Stack cuts the waste.</p>
    <div class="features">
      <div class="feature-card">
        <div class="feature-icon">&#x1F517;</div>
        <h3>Knowledge Graph</h3>
        <p>Native memory does flat text search — so your agent re-reads everything to find connections. Memory Stack builds a knowledge graph locally. Ask "what depends on service X?" and get the answer instantly, without burning tokens on irrelevant context.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F9E0;</div>
        <h3>Self-Evolving Memory</h3>
        <p>Messy memory = wasted tokens. When 5 scattered notes say the same thing, your AI reads all 5 and you pay for all 5. Memory Stack merges them into one clear entry. Cleaner memory, lower cost, better answers.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F6E1;</div>
        <h3>Compaction Rescue</h3>
        <p>When your agent forgets a decision, you explain it again. That costs tokens. Memory Stack saves key facts before compression and brings them back automatically — so you never pay to re-explain the same thing twice.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F50D;</div>
        <h3>6-Engine Search</h3>
        <p>Native memory searches one way and hopes for the best. Memory Stack runs 6 engines and picks the best results across all of them. Finds the right memory on the first try — instead of your agent guessing and wasting tokens on wrong context.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F9F9;</div>
        <h3>Memory Health</h3>
        <p>Duplicates and junk in your memory cost real money every time your AI reads them. Memory Health scores your memory 0-100, shows exactly what's wasting tokens, and helps you clean it up. Think of it as a bill audit for your AI.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x26A1;</div>
        <h3>Zero Config, Zero API Keys</h3>
        <p>No paid embedding providers. No API keys. Three local AI models handle everything on your machine. The $49 you pay is the last dollar you spend — no recurring costs, no per-query charges, no surprises on your bill.</p>
      </div>
    </div>
  </div>

  <div class="section" id="how">
    <div class="section-label">// how it works</div>
    <h2>Install once. Save on every conversation.</h2>
    <p class="section-desc">Memory Stack plugs into OpenClaw as a native memory provider. Starts saving tokens immediately.</p>
    <div class="routing-grid">
      <div class="route-item">
        <div>
          <div class="route-label">You talk to OpenClaw</div>
          <div class="route-arrow">&rarr; <span class="route-target">auto-recall kicks in</span></div>
        </div>
      </div>
      <div class="route-item">
        <div>
          <div class="route-label">Relevant memories found</div>
          <div class="route-arrow">&rarr; <span class="route-target">injected before response</span></div>
        </div>
      </div>
      <div class="route-item">
        <div>
          <div class="route-label">Agent responds</div>
          <div class="route-arrow">&rarr; <span class="route-target">key facts saved to rescue</span></div>
        </div>
      </div>
      <div class="route-item">
        <div>
          <div class="route-label">Conversation gets long</div>
          <div class="route-arrow">&rarr; <span class="route-target">compaction happens</span></div>
        </div>
      </div>
      <div class="route-item">
        <div>
          <div class="route-label">You ask about old decisions</div>
          <div class="route-arrow">&rarr; <span class="route-target">rescue store has them</span></div>
        </div>
      </div>
    </div>
  </div>

  <div class="section" id="compare">
    <div class="section-label">// vs native memory</div>
    <h2>Side by side. Plain and simple.</h2>
    <p class="section-desc">Same agent, same conversations. One remembers more, uses fewer tokens, and finds things faster.</p>

    <div class="compare-header-cards">
      <div class="compare-stat">
        <div class="compare-stat-number">6</div>
        <div class="compare-stat-label">search engines<br/><span>vs native's 2</span></div>
      </div>
      <div class="compare-stat">
        <div class="compare-stat-number">3</div>
        <div class="compare-stat-label">local AI models<br/><span>vs native's 0</span></div>
      </div>
      <div class="compare-stat">
        <div class="compare-stat-number">90%</div>
        <div class="compare-stat-label">fewer tokens per search<br/><span>lower API bill</span></div>
      </div>
    </div>

    <div class="compare-table-wrap">
      <table class="compare-table">
        <thead>
          <tr>
            <th></th>
            <th>Native Memory</th>
            <th>Memory Stack</th>
          </tr>
        </thead>
        <tbody>
          <tr class="compare-group"><td colspan="3">Remembers longer</td></tr>
          <tr>
            <td>What happens when the conversation gets too long?</td>
            <td class="no">Old messages get compressed. Decisions disappear.</td>
            <td class="yes">Key facts are saved before compression and brought back automatically.</td>
          </tr>
          <tr>
            <td>Can it remember things from last week?</td>
            <td class="no">Only if it's still in the conversation window.</td>
            <td class="yes">Yes. Recent memories rank higher, but older ones are still searchable.</td>
          </tr>
