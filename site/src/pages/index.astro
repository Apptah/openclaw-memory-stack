---
import Layout from "../layouts/Layout.astro";
---
<Layout title="OpenClaw Memory Stack">
  <style>
    /* ── Nav ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 2rem;
      background: rgba(6, 8, 12, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      font-family: var(--font-mono);
      font-weight: 700;
      font-size: 0.95rem;
      color: var(--accent);
      letter-spacing: -0.02em;
    }
    .nav-logo span { color: var(--muted); }
    .nav-claw-icon { vertical-align: -4px; margin-right: 4px; }
    .nav-links { display: flex; gap: 1.5rem; align-items: center; }
    .nav-links a { color: var(--muted); font-size: 0.85rem; font-weight: 500; }
    .nav-links a:hover { color: var(--fg-bright); text-shadow: none; }
    .nav-toggle { display: none; background: none; border: none; cursor: pointer; padding: 0.25rem; color: var(--muted); }
    .nav-toggle:hover { color: var(--fg-bright); }
    @media (max-width: 640px) {
      .nav-toggle { display: block; }
      .nav-links {
        display: none;
        position: absolute;
        top: 100%;
        left: 0; right: 0;
        flex-direction: column;
        gap: 0;
        background: rgb(6, 8, 12);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
        padding: 0.5rem 0;
      }
      .nav-links.open { display: flex; }
      .nav-links a {
        padding: 0.75rem 1.5rem;
        font-size: 0.95rem;
        width: 100%;
      }
      .nav-links a:hover { background: rgba(0, 229, 255, 0.05); }
    }

    /* ── Hero ── */
    .hero {
      max-width: 900px;
      margin: 0 auto;
      padding: 10rem 2rem 5rem;
      text-align: center;
      position: relative;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -60%);
      width: 600px; height: 600px;
      background: radial-gradient(circle, var(--accent-dim) 0%, transparent 70%);
      pointer-events: none;
      z-index: -1;
    }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--accent);
      background: var(--accent-dim);
      border: 1px solid var(--border-bright);
      border-radius: 999px;
      padding: 0.35rem 1rem;
      margin-bottom: 2rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .badge::before { content: '//'; color: var(--muted); }
    .badge { transition: all 0.2s; }
    .badge:hover {
      background: rgba(0, 229, 255, 0.18);
      border-color: var(--accent);
      box-shadow: 0 0 12px var(--accent-glow);
      transform: translateY(-1px);
    }
    .hero h1 {
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 1.5rem;
      letter-spacing: -0.03em;
      color: var(--fg-bright);
    }
    .hero h1 .glow {
      color: var(--accent);
      text-shadow: 0 0 40px var(--accent-glow);
    }
    .hero .subtitle {
      font-size: 1.15rem;
      color: var(--muted);
      max-width: 560px;
      margin: 0 auto 3rem;
      line-height: 1.7;
    }
    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      background: var(--accent);
      color: var(--bg);
      font-weight: 700;
      padding: 0.85rem 2.2rem;
      border-radius: 8px;
      font-size: 1rem;
      border: none;
      cursor: pointer;
      transition: all 0.25s;
      text-decoration: none;
      font-family: var(--font-sans);
    }
    .hero-cta:hover {
      background: var(--accent-hover);
      color: var(--bg);
      text-shadow: none;
      box-shadow: 0 0 30px var(--accent-glow);
      transform: translateY(-1px);
    }
    .hero-price {
      display: block;
      margin-top: 1rem;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--muted);
    }

    /* ── Terminal demo ── */
    .terminal-wrap {
      max-width: 700px;
      margin: 0 auto 6rem;
      padding: 0 2rem;
    }
    .terminal {
      background: var(--surface);
      border: 1px solid var(--border-bright);
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 0 40px rgba(0, 229, 255, 0.05);
      transition: box-shadow 0.3s, border-color 0.3s;
    }
    .terminal:hover {
      border-color: var(--accent);
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 0 60px rgba(0, 229, 255, 0.1);
    }
    .terminal-bar {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 0.75rem 1rem;
      background: var(--surface-elevated);
      border-bottom: 1px solid var(--border);
    }
    .terminal-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--border-bright);
    }
    .terminal-dot:nth-child(1) { background: #ff5f57; }
    .terminal-dot:nth-child(2) { background: #ffbd2e; }
    .terminal-dot:nth-child(3) { background: #28c840; }
    .terminal-title {
      flex: 1;
      text-align: center;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--muted);
      margin-right: 40px;
    }
    .terminal-body {
      padding: 1.25rem 1.5rem;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      line-height: 1.8;
      overflow-x: auto;
    }
    .terminal-body .prompt { color: var(--accent); }
    .terminal-body .cmd { color: var(--fg-bright); }
    .terminal-body .comment { color: var(--muted); font-style: italic; }
    .terminal-body .output { color: var(--muted); }
    .terminal-body .success { color: var(--green); }

    /* ── Section titles ── */
    .section {
      max-width: 900px;
      margin: 0 auto;
      padding: 4rem 2rem;
    }
    .section-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--accent);
      margin-bottom: 0.75rem;
    }
    .section h2 {
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--fg-bright);
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
    }
    .section .section-desc {
      color: var(--muted);
      max-width: 500px;
      margin-bottom: 2.5rem;
    }

    /* ── Feature cards ── */
    .features {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1rem;
    }
    .feature-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.75rem;
      transition: all 0.3s;
    }
    .feature-card:hover {
      border-color: var(--accent);
      box-shadow: 0 4px 24px rgba(0, 229, 255, 0.1), 0 0 0 1px rgba(0, 229, 255, 0.08);
      transform: translateY(-4px);
    }
    .feature-card:hover .feature-icon {
      background: rgba(0, 229, 255, 0.2);
      box-shadow: 0 0 12px var(--accent-glow);
    }
    .feature-icon {
      width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      background: var(--accent-dim);
      border-radius: 8px;
      margin-bottom: 1rem;
      font-size: 1rem;
      transition: all 0.3s;
    }
    .feature-card h3 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--fg-bright);
      margin-bottom: 0.5rem;
      font-family: var(--font-mono);
    }
    .feature-card p {
      font-size: 0.88rem;
      color: var(--muted);
      line-height: 1.6;
    }
    .feature-card .v2-badge {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      font-weight: 700;
      color: #00e676;
      background: rgba(0, 230, 118, 0.1);
      border: 1px solid rgba(0, 230, 118, 0.3);
      border-radius: 4px;
      padding: 0.15rem 0.5rem;
      margin-left: 0.5rem;
      vertical-align: middle;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    /* ── Pricing plans ── */
    .pricing-plans {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 1.5rem;
      max-width: 760px;
      margin: 2rem auto 0;
    }
    .plan-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
      text-align: center;
    }
    .plan-card.featured {
      border-color: var(--accent);
      box-shadow: 0 0 20px var(--accent-glow);
      position: relative;
    }
    .plan-card.featured::before {
      content: 'RECOMMENDED';
      position: absolute;
      top: -0.7rem;
      left: 50%;
      transform: translateX(-50%);
      font-family: var(--font-mono);
      font-size: 0.65rem;
      font-weight: 700;
      color: var(--accent);
      background: var(--bg);
      border: 1px solid var(--accent);
      border-radius: 4px;
      padding: 0.15rem 0.75rem;
      letter-spacing: 0.05em;
    }
    .plan-card h3 {
      font-family: var(--font-mono);
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--fg-bright);
      margin-bottom: 0.5rem;
    }
    .plan-card .plan-price {
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--fg-bright);
      margin: 0.5rem 0 0.25rem;
    }
    .plan-card .plan-price span {
      font-size: 1rem;
      font-weight: 400;
      color: var(--muted);
    }
    .plan-card .plan-note {
      font-size: 0.8rem;
      color: var(--muted);
      margin-bottom: 1.5rem;
    }
    .plan-card ul {
      text-align: left;
      list-style: none;
      padding: 0;
      margin: 0 0 1.5rem;
    }
    .plan-card ul li {
      font-size: 0.85rem;
      color: var(--muted);
      padding: 0.4rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .plan-card ul li::before {
      content: '✓ ';
      color: #00e676;
      font-weight: 700;
    }
    .plan-card ul li.disabled {
      color: rgba(255,255,255,0.25);
    }
    .plan-card ul li.disabled::before {
      content: '— ';
      color: rgba(255,255,255,0.15);
    }

    /* ── Routing flow ── */
    .routing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 0.75rem;
    }
    .route-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem 1.25rem;
      font-size: 0.85rem;
      overflow: hidden;
      word-break: break-word;
      transition: all 0.25s;
    }
    .route-item:hover {
      border-color: var(--border-bright);
      background: rgba(0, 229, 255, 0.03);
      transform: translateX(4px);
    }
    .route-item:hover .route-arrow {
      text-shadow: 0 0 8px var(--accent-glow);
    }
    .route-label {
      color: var(--fg-bright);
      font-weight: 500;
      font-size: 0.82rem;
    }
    .route-arrow {
      color: var(--accent);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      white-space: nowrap;
    }
    .route-target {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--muted);
    }

    /* ── Compare stats ── */
    .compare-header-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-bottom: 3rem;
    }
    .compare-stat {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.5rem;
      text-align: center;
      transition: all 0.25s;
    }
    .compare-stat:hover {
      border-color: var(--border-bright);
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    }
    .compare-stat:hover .compare-stat-number {
      text-shadow: 0 0 20px var(--accent-glow);
    }
    .compare-stat-number {
      font-family: var(--font-mono);
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--accent);
      line-height: 1;
      margin-bottom: 0.5rem;
    }
    .compare-stat-label {
      font-size: 0.82rem;
      color: var(--fg-bright);
      line-height: 1.4;
    }
    .compare-stat-label span {
      color: var(--muted);
      font-size: 0.75rem;
    }

    /* ── Compare table ── */
    .compare-table-wrap {
      overflow-x: auto;
      margin: 0 -0.5rem;
    }
    .compare-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
    }
    .compare-table th {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent);
      text-align: left;
      padding: 0.75rem 1rem;
      border-bottom: 2px solid var(--border-bright);
    }
    .compare-table th:not(:first-child) {
      text-align: center;
      width: 35%;
    }
    .compare-table td {
      padding: 0.75rem 1rem;
      border-bottom: 1px solid var(--border);
      color: var(--fg);
      vertical-align: top;
      line-height: 1.5;
    }
    .compare-table td:not(:first-child) {
      text-align: left;
    }
    .compare-table td:first-child {
      font-weight: 500;
      color: var(--fg-bright);
      width: 30%;
    }
    .compare-table tr:hover {
      background: rgba(0, 229, 255, 0.03);
    }
    .compare-table td.yes {
      color: #28c840;
    }
    .compare-table td.no {
      color: var(--muted);
    }
    .compare-table td.partial {
      color: #ffbd2e;
    }
    .compare-group td {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--accent);
      padding: 1.5rem 1rem 0.5rem;
      border-bottom: 1px solid var(--border-bright);
      font-weight: 700;
    }


    /* ── CTA ── */
    .cta-section {
      max-width: 900px;
      margin: 0 auto;
      padding: 4rem 2rem;
    }
    .cta-box {
      text-align: center;
      padding: 4rem 2rem;
      background: var(--surface);
      border: 1px solid var(--border-bright);
      border-radius: 16px;
      position: relative;
      overflow: hidden;
      transition: box-shadow 0.3s, border-color 0.3s;
    }
    .cta-box:hover {
      border-color: var(--accent);
      box-shadow: 0 0 40px rgba(0, 229, 255, 0.08);
    }
    .cta-box::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at top, var(--accent-dim) 0%, transparent 60%);
      pointer-events: none;
    }
    .cta-box .price {
      font-size: 3.5rem;
      font-weight: 800;
      color: var(--fg-bright);
      margin-bottom: 0.25rem;
      position: relative;
      font-family: var(--font-mono);
    }
    .cta-box .price-note {
      color: var(--muted);
      margin-bottom: 2rem;
      font-size: 0.9rem;
      position: relative;
    }
    .cta-box .cta-btn-wrap { position: relative; }

    /* ── Disclaimers ── */
    .disclaimers-section {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 2rem 4rem;
    }
    .disclaimers {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 0.75rem;
      list-style: none;
    }
    .disclaimers li {
      font-size: 0.82rem;
      color: var(--muted);
      padding: 0.85rem 1rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      line-height: 1.5;
      transition: all 0.2s;
    }
    .disclaimers li:hover {
      border-color: var(--border-bright);
      background: rgba(0, 229, 255, 0.03);
      transform: translateY(-1px);
    }
    .disclaimers li strong {
      color: var(--fg);
      font-weight: 600;
    }

    /* ── FAQ ── */
    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .faq-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      transition: border-color 0.2s;
    }
    .faq-item[open] {
      border-color: var(--border-bright);
    }
    .faq-item summary {
      padding: 1rem 1.25rem;
      cursor: pointer;
      font-weight: 600;
      color: var(--fg-bright);
      font-size: 0.92rem;
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .faq-item summary::after {
      content: '+';
      font-family: var(--font-mono);
      color: var(--accent);
      font-size: 1.1rem;
      transition: transform 0.2s;
    }
    .faq-item[open] summary::after {
      transform: rotate(45deg);
    }
    .faq-item summary:hover { background: rgba(0, 229, 255, 0.03); }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item p {
      padding: 0 1.25rem 1rem;
      font-size: 0.88rem;
      color: var(--muted);
      line-height: 1.7;
    }
    .faq-item strong {
      color: var(--fg);
    }

    /* ── Footer ── */
    footer {
      text-align: center;
      padding: 3rem 2rem;
      color: var(--muted);
      font-size: 0.8rem;
      border-top: 1px solid var(--border);
      font-family: var(--font-mono);
    }
    footer .links { display: flex; gap: 1.5rem; justify-content: center; margin-top: 0.75rem; }
    footer .links a { color: var(--muted); font-size: 0.75rem; }

    @media (max-width: 640px) {
      .compare-header-cards {
        grid-template-columns: 1fr;
      }
    }

    /* ── Responsive ── */
    @media (max-width: 640px) {
      nav { padding: 0.75rem 1rem; }
      .hero { padding: 8rem 1.25rem 3rem; }
      .section { padding: 3rem 1.25rem; }
      .terminal-wrap { padding: 0 1.25rem; }
      .cta-section { padding: 3rem 1.25rem; }
    }

    /* ── Cursor spotlight ── */
    .cursor-glow {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 50;
      opacity: 0;
      transition: opacity 0.3s;
      background: radial-gradient(
        600px circle at var(--glow-x, 50%) var(--glow-y, 50%),
        rgba(0, 229, 255, 0.06),
        transparent 60%
      );
    }
    .cursor-glow.active { opacity: 1; }
    @media (hover: none) and (pointer: coarse) {
      .cursor-glow { display: none; }
    }
  </style>

  <div class="cursor-glow" id="cursor-glow"></div>

  <nav>
    <div class="nav-logo">
      <svg class="nav-claw-icon" width="24" height="24" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs><linearGradient id="lg" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#ff4d4d"/><stop offset="100%" stop-color="#991b1b"/></linearGradient></defs>
        <path d="M60 10 C30 10 15 35 15 55 C15 75 30 95 45 100 L45 110 L55 110 L55 100 C55 100 60 102 65 100 L65 110 L75 110 L75 100 C90 95 105 75 105 55 C105 35 90 10 60 10Z" fill="url(#lg)"/>
        <path d="M20 45 C5 40 0 50 5 60 C10 70 20 65 25 55 C28 48 25 45 20 45Z" fill="url(#lg)"/>
        <path d="M100 45 C115 40 120 50 115 60 C110 70 100 65 95 55 C92 48 95 45 100 45Z" fill="url(#lg)"/>
        <path d="M45 15 Q35 5 30 8" stroke="#ff4d4d" stroke-width="3" stroke-linecap="round"/>
        <path d="M75 15 Q85 5 90 8" stroke="#ff4d4d" stroke-width="3" stroke-linecap="round"/>
        <circle cx="45" cy="35" r="6" fill="#050810"/><circle cx="75" cy="35" r="6" fill="#050810"/>
        <circle cx="46" cy="34" r="2.5" fill="#00e5cc"/><circle cx="76" cy="34" r="2.5" fill="#00e5cc"/>
      </svg>
      openclaw<span>/memory-stack</span>
    </div>
    <button class="nav-toggle" id="nav-toggle" aria-label="Menu">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <div class="nav-links" id="nav-links">
      <a href="#features">Features</a>
      <a href="#compare">vs Native</a>
      <a href="#faq">FAQ</a>
      <a href="https://clawhub.ai/Apptah/openclaw-memory-stack" target="_blank" rel="noopener">ClawHub</a>
      <a href="https://github.com/Apptah/openclaw-memory-stack" target="_blank" rel="noopener">GitHub</a>
    </div>
  </nav>

  <div class="hero">
    <div class="badge">v0.5.8 — Open Source · MIT</div>
    <h1>Total recall.<br/><span class="glow">90% fewer tokens.</span></h1>
    <p class="subtitle">
      Your agent forgets past decisions and burns tokens re-reading the same context.
      Memory Stack runs 5 search engines plus built-in code search — all locally — returns only what matters, and never loses a fact.
      Works across all your tools, cleans up after itself, and updates automatically.
    </p>
