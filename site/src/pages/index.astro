  <script>
    const API = (window as any).__API_BASE__;
    async function handleBuy(e: Event) {
      e.preventDefault();
      const btn = e.currentTarget as HTMLButtonElement;
      const orig = btn.innerHTML;
      btn.textContent = "Connecting to Stripe...";
      btn.disabled = true;
      try {
        const res = await fetch(`${API}/api/checkout`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            success_url: window.location.origin + "/thanks?session_id={CHECKOUT_SESSION_ID}",
            cancel_url: window.location.origin + "/",
          }),
        });
        const data = await res.json();
        if (data.checkout_url) window.location.href = data.checkout_url;
      } catch {
        btn.innerHTML = orig;
        btn.disabled = false;
        alert("Connection failed. Please try again.");
      }
    }
    document.getElementById("buy-btn")?.addEventListener("click", handleBuy);
    document.getElementById("buy-btn-2")?.addEventListener("click", handleBuy);

    // Mobile nav toggle
    document.getElementById("nav-toggle")?.addEventListener("click", () => {
      document.getElementById("nav-links")?.classList.toggle("open");
    });
    // Close menu on link click
    document.querySelectorAll("#nav-links a").forEach(a => {
      a.addEventListener("click", () => {
        document.getElementById("nav-links")?.classList.remove("open");
      });
    });
  </script>
