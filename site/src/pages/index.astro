---
import Layout from "../layouts/Layout.astro";
---
<Layout title="OpenClaw Memory Stack">
  <style>
    /* ── Nav ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 2rem;
      background: rgba(6, 8, 12, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      font-family: var(--font-mono);
      font-weight: 700;
      font-size: 0.95rem;
      color: var(--accent);
      letter-spacing: -0.02em;
    }
    .nav-logo span { color: var(--muted); }
    .nav-links { display: flex; gap: 1.5rem; align-items: center; }
    .nav-links a { color: var(--muted); font-size: 0.85rem; font-weight: 500; }
    .nav-links a:hover { color: var(--fg-bright); text-shadow: none; }

    /* ── Hero ── */
    .hero {
      max-width: 900px;
      margin: 0 auto;
      padding: 10rem 2rem 5rem;
      text-align: center;
      position: relative;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -60%);
      width: 600px; height: 600px;
      background: radial-gradient(circle, var(--accent-dim) 0%, transparent 70%);
      pointer-events: none;
      z-index: -1;
    }
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--accent);
      background: var(--accent-dim);
      border: 1px solid var(--border-bright);
      border-radius: 999px;
      padding: 0.35rem 1rem;
      margin-bottom: 2rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .badge::before { content: '//'; color: var(--muted); }
    .hero h1 {
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 1.5rem;
      letter-spacing: -0.03em;
      color: var(--fg-bright);
    }
    .hero h1 .glow {
      color: var(--accent);
      text-shadow: 0 0 40px var(--accent-glow);
    }
    .hero .subtitle {
      font-size: 1.15rem;
      color: var(--muted);
      max-width: 560px;
      margin: 0 auto 3rem;
      line-height: 1.7;
    }
    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      background: var(--accent);
      color: var(--bg);
      font-weight: 700;
      padding: 0.85rem 2.2rem;
      border-radius: 8px;
      font-size: 1rem;
      border: none;
      cursor: pointer;
      transition: all 0.25s;
      text-decoration: none;
      font-family: var(--font-sans);
    }
    .hero-cta:hover {
      background: var(--accent-hover);
      color: var(--bg);
      text-shadow: none;
      box-shadow: 0 0 30px var(--accent-glow);
      transform: translateY(-1px);
    }
    .hero-price {
      display: block;
      margin-top: 1rem;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--muted);
    }

    /* ── Terminal demo ── */
    .terminal-wrap {
      max-width: 700px;
      margin: 0 auto 6rem;
      padding: 0 2rem;
    }
    .terminal {
      background: var(--surface);
      border: 1px solid var(--border-bright);
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 0 40px rgba(0, 229, 255, 0.05);
    }
    .terminal-bar {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 0.75rem 1rem;
      background: var(--surface-elevated);
      border-bottom: 1px solid var(--border);
    }
    .terminal-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--border-bright);
    }
    .terminal-dot:nth-child(1) { background: #ff5f57; }
    .terminal-dot:nth-child(2) { background: #ffbd2e; }
    .terminal-dot:nth-child(3) { background: #28c840; }
    .terminal-title {
      flex: 1;
      text-align: center;
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: var(--muted);
      margin-right: 40px;
    }
    .terminal-body {
      padding: 1.25rem 1.5rem;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      line-height: 1.8;
      overflow-x: auto;
    }
    .terminal-body .prompt { color: var(--accent); }
    .terminal-body .cmd { color: var(--fg-bright); }
    .terminal-body .comment { color: var(--muted); font-style: italic; }
    .terminal-body .output { color: var(--muted); }
    .terminal-body .success { color: var(--green); }

    /* ── Section titles ── */
    .section {
      max-width: 900px;
      margin: 0 auto;
      padding: 4rem 2rem;
    }
    .section-label {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--accent);
      margin-bottom: 0.75rem;
    }
    .section h2 {
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--fg-bright);
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
    }
    .section .section-desc {
      color: var(--muted);
      max-width: 500px;
      margin-bottom: 2.5rem;
    }

    /* ── Feature cards ── */
    .features {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1rem;
    }
    .feature-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.75rem;
      transition: all 0.3s;
    }
    .feature-card:hover {
      border-color: var(--border-bright);
      box-shadow: 0 0 20px rgba(0, 229, 255, 0.05);
      transform: translateY(-2px);
    }
    .feature-icon {
      width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      background: var(--accent-dim);
      border-radius: 8px;
      margin-bottom: 1rem;
      font-size: 1rem;
    }
    .feature-card h3 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--fg-bright);
      margin-bottom: 0.5rem;
      font-family: var(--font-mono);
    }
    .feature-card p {
      font-size: 0.88rem;
      color: var(--muted);
      line-height: 1.6;
    }

    /* ── Routing flow ── */
    .routing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 0.75rem;
    }
    .route-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem 1.25rem;
      font-size: 0.85rem;
      overflow: hidden;
      word-break: break-word;
    }
    .route-label {
      color: var(--fg-bright);
      font-weight: 500;
      font-size: 0.82rem;
    }
    .route-arrow {
      color: var(--accent);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      white-space: nowrap;
    }
    .route-target {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--muted);
    }

    /* ── Compare table ── */
    .compare-table-wrap {
      overflow-x: auto;
      margin: 0 -0.5rem;
    }
    .compare-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
    }
    .compare-table th {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--accent);
      text-align: left;
      padding: 0.75rem 1rem;
      border-bottom: 2px solid var(--border-bright);
    }
    .compare-table th:not(:first-child) {
      text-align: center;
    }
    .compare-table td {
      padding: 0.65rem 1rem;
      border-bottom: 1px solid var(--border);
      color: var(--fg);
    }
    .compare-table td:not(:first-child) {
      text-align: center;
    }
    .compare-table td:first-child {
      font-weight: 500;
      color: var(--fg-bright);
      white-space: nowrap;
    }
    .compare-table tr:hover {
      background: rgba(0, 229, 255, 0.03);
    }
    .compare-table td.yes {
      color: #28c840;
    }
    .compare-table td.no {
      color: var(--muted);
    }
    .compare-table td.partial {
      color: #ffbd2e;
    }

    /* ── CTA ── */
    .cta-section {
      max-width: 900px;
      margin: 0 auto;
      padding: 4rem 2rem;
    }
    .cta-box {
      text-align: center;
      padding: 4rem 2rem;
      background: var(--surface);
      border: 1px solid var(--border-bright);
      border-radius: 16px;
      position: relative;
      overflow: hidden;
    }
    .cta-box::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at top, var(--accent-dim) 0%, transparent 60%);
      pointer-events: none;
    }
    .cta-box .price {
      font-size: 3.5rem;
      font-weight: 800;
      color: var(--fg-bright);
      margin-bottom: 0.25rem;
      position: relative;
      font-family: var(--font-mono);
    }
    .cta-box .price-note {
      color: var(--muted);
      margin-bottom: 2rem;
      font-size: 0.9rem;
      position: relative;
    }
    .cta-box .cta-btn-wrap { position: relative; }

    /* ── Disclaimers ── */
    .disclaimers-section {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 2rem 4rem;
    }
    .disclaimers {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 0.75rem;
      list-style: none;
    }
    .disclaimers li {
      font-size: 0.82rem;
      color: var(--muted);
      padding: 0.85rem 1rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      line-height: 1.5;
    }
    .disclaimers li strong {
      color: var(--fg);
      font-weight: 600;
    }

    /* ── Footer ── */
    footer {
      text-align: center;
      padding: 3rem 2rem;
      color: var(--muted);
      font-size: 0.8rem;
      border-top: 1px solid var(--border);
      font-family: var(--font-mono);
    }
    footer .links { display: flex; gap: 1.5rem; justify-content: center; margin-top: 0.75rem; }
    footer .links a { color: var(--muted); font-size: 0.75rem; }

    /* ── Responsive ── */
    @media (max-width: 640px) {
      nav { padding: 0.75rem 1rem; }
      .hero { padding: 8rem 1.25rem 3rem; }
      .section { padding: 3rem 1.25rem; }
      .terminal-wrap { padding: 0 1.25rem; }
      .cta-section { padding: 3rem 1.25rem; }
    }
  </style>

  <nav>
    <div class="nav-logo">openclaw<span>/memory-stack</span></div>
    <div class="nav-links">
      <a href="#features">Features</a>
      <a href="#compare">vs Native</a>
      <a href="/manage">Manage License</a>
    </div>
  </nav>

  <div class="hero">
    <div class="badge">v2 — OpenClaw Plugin</div>
    <h1>Long conversations.<br/><span class="glow">Nothing lost.</span></h1>
    <p class="subtitle">
      Memory plugin for OpenClaw that runs 100% locally. Smarter search, memory quality checks,
      and compaction rescue — so your agent remembers everything, no matter how long the conversation.
      No API keys. No subscriptions. Just install and go.
    </p>
    <button class="hero-cta" id="buy-btn">
      Get Memory Stack
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <span class="hero-price">$49 &mdash; one-time purchase, no subscription</span>
  </div>

  <div class="terminal-wrap">
    <div class="terminal">
      <div class="terminal-bar">
        <div class="terminal-dot"></div>
        <div class="terminal-dot"></div>
        <div class="terminal-dot"></div>
        <div class="terminal-title">openclaw-memory</div>
      </div>
      <div class="terminal-body">
        <div><span class="comment"># Install — one command, done</span></div>
        <div><span class="prompt">$</span> <span class="cmd">./install.sh --key=oc-starter-xxxxxxxxxxxx</span></div>
        <div><span class="success">  [OK]  License verified</span></div>
        <div><span class="success">  [OK]  Registered as OpenClaw memory plugin</span></div>
        <div>&nbsp;</div>
        <div><span class="comment"># Restart OpenClaw — memory is now active</span></div>
        <div><span class="prompt">$</span> <span class="cmd">openclaw gateway restart</span></div>
        <div><span class="success">  [OK]  Memory Stack v2 registered (engines: fts5+qmd+rescue)</span></div>
        <div>&nbsp;</div>
        <div><span class="comment"># Just talk — memory works in the background</span></div>
        <div><span class="output">  You: What did we decide about the API design?</span></div>
        <div><span class="success">  [memory_search] Found 3 results (engines: fts5, qmd, rescue)</span></div>
        <div><span class="output">  Agent: We decided to use REST with /api/v2/...</span></div>
      </div>
    </div>
  </div>

  <div class="section" id="features">
    <div class="section-label">// why memory stack</div>
    <h2>What OpenClaw's built-in memory can't do.</h2>
    <p class="section-desc">Three features that make long conversations actually work.</p>
    <div class="features">
      <div class="feature-card">
        <div class="feature-icon">&#x1F517;</div>
        <h3>Knowledge Graph</h3>
        <p>Native memory does flat text search. Memory Stack builds a local knowledge graph from your conversations — tracking projects, people, APIs, and how they connect. Ask "what depends on service X?" and get real answers.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F9E0;</div>
        <h3>Self-Evolving Memory</h3>
        <p>Memories pile up and get noisy. Memory Stack finds clusters of similar entries and suggests consolidation — turning 5 scattered notes about the same topic into one clear summary. Your memory gets sharper over time, not messier.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F6E1;</div>
        <h3>Compaction Rescue</h3>
        <p>Long conversations get compressed — and key decisions get lost. Memory Stack saves important facts (decisions, deadlines, requirements) before compression happens, and brings them back automatically. No matter how long the conversation.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F50D;</div>
        <h3>Smarter Search</h3>
        <p>MMR diversity ranking prevents redundant results. Temporal decay prioritizes recent memories. Session indexing searches across past conversations. All running locally — no API keys, no extra cost.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F9F9;</div>
        <h3>Memory Health</h3>
        <p>Built-in quality checks find duplicates, stale entries, and noise. Scores your memory 0-100 and tells you exactly what to clean up. Never deletes anything automatically — you stay in control.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x26A1;</div>
        <h3>Zero Config</h3>
        <p>Install, restart OpenClaw, done. No embedding providers to configure, no API keys to manage, no project initialization needed. Memory improves the moment you install it.</p>
      </div>
    </div>
  </div>

  <div class="section" id="how">
    <div class="section-label">// how it works</div>
    <h2>Install once. Memory improves forever.</h2>
    <p class="section-desc">Memory Stack plugs into OpenClaw as a native memory provider. No manual setup after install.</p>
    <div class="routing-grid">
      <div class="route-item">
        <div>
          <div class="route-label">You talk to OpenClaw</div>
          <div class="route-arrow">&rarr; <span class="route-target">auto-recall kicks in</span></div>
        </div>
      </div>
      <div class="route-item">
        <div>
          <div class="route-label">Relevant memories found</div>
          <div class="route-arrow">&rarr; <span class="route-target">injected before response</span></div>
        </div>
      </div>
      <div class="route-item">
        <div>
          <div class="route-label">Agent responds</div>
          <div class="route-arrow">&rarr; <span class="route-target">key facts saved to rescue</span></div>
        </div>
      </div>
      <div class="route-item">
        <div>
          <div class="route-label">Conversation gets long</div>
          <div class="route-arrow">&rarr; <span class="route-target">compaction happens</span></div>
        </div>
      </div>
      <div class="route-item">
        <div>
          <div class="route-label">You ask about old decisions</div>
          <div class="route-arrow">&rarr; <span class="route-target">rescue store has them</span></div>
        </div>
      </div>
    </div>
  </div>

  <div class="section" id="compare">
    <div class="section-label">// vs native memory</div>
    <h2>What you get that built-in memory doesn't have.</h2>
    <p class="section-desc">OpenClaw's native memory is good. Memory Stack makes it better.</p>
    <div class="compare-table-wrap">
      <table class="compare-table">
        <thead>
          <tr>
            <th>Feature</th>
            <th>Native Memory</th>
            <th>Memory Stack</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Text search (BM25)</td>
            <td class="yes">Yes</td>
            <td class="yes">Yes</td>
          </tr>
          <tr>
            <td>Vector search</td>
            <td class="yes">Yes (needs API key or local setup)</td>
            <td class="yes">Yes (QMD, zero config)</td>
          </tr>
          <tr>
            <td>Hybrid search + MMR</td>
            <td class="yes">Yes</td>
            <td class="yes">Yes</td>
          </tr>
          <tr>
            <td>Temporal decay</td>
            <td class="yes">Yes</td>
            <td class="yes">Yes</td>
          </tr>
          <tr>
            <td>Knowledge graph</td>
            <td class="no">No</td>
            <td class="yes">Yes — tracks entities and relationships</td>
          </tr>
          <tr>
            <td>Self-evolving memory</td>
            <td class="no">No</td>
            <td class="yes">Yes — finds duplicates, suggests consolidation</td>
          </tr>
          <tr>
            <td>Compaction rescue</td>
            <td class="no">LLM-based flush only (costs tokens)</td>
            <td class="yes">Rule-based extraction (zero token cost)</td>
          </tr>
          <tr>
            <td>Memory health check</td>
            <td class="no">No</td>
            <td class="yes">Yes — scores quality 0-100</td>
          </tr>
          <tr>
            <td>Multi-engine search</td>
            <td class="no">Single backend</td>
            <td class="yes">5 engines with fallback routing</td>
          </tr>
          <tr>
            <td>Session search</td>
            <td class="partial">Experimental</td>
            <td class="yes">Yes</td>
          </tr>
          <tr>
            <td>Embedding setup needed</td>
            <td class="no">Yes — requires provider config</td>
            <td class="yes">No — works out of the box</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="cta-section">
    <div class="cta-box">
      <div class="price">$49</div>
      <div class="price-note">One-time purchase. No subscription. No SaaS. Just files.</div>
      <div class="cta-btn-wrap">
        <button class="hero-cta" id="buy-btn-2">
          Get Memory Stack
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div class="disclaimers-section">
    <ul class="disclaimers">
      <li><strong>OpenClaw plugin.</strong> Installs as a native memory provider. Requires OpenClaw 2026.3.2 or later.</li>
      <li><strong>No embedding setup.</strong> BM25 search works instantly. Optional QMD vector search runs locally with Bun — no external API needed.</li>
      <li><strong>macOS + Linux.</strong> Windows via WSL2.</li>
      <li><strong>One-time purchase.</strong> You own the code. No subscription. No data leaves your machine.</li>
    </ul>
  </div>

  <footer>
    <div>openclaw/memory-stack &copy; 2026</div>
    <div class="links">
      <a href="/manage">Manage License</a>
      <a href="/thanks">Post-Purchase</a>
    </div>
  </footer>

  <script>
    const API = (window as any).__API_BASE__;
    async function handleBuy(e: Event) {
      e.preventDefault();
      const btn = e.currentTarget as HTMLButtonElement;
      const orig = btn.innerHTML;
      btn.textContent = "Connecting to Stripe...";
      btn.disabled = true;
      try {
        const res = await fetch(`${API}/api/checkout`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            success_url: window.location.origin + "/thanks?session_id={CHECKOUT_SESSION_ID}",
            cancel_url: window.location.origin + "/",
          }),
        });
        const data = await res.json();
        if (data.checkout_url) window.location.href = data.checkout_url;
      } catch {
        btn.innerHTML = orig;
        btn.disabled = false;
        alert("Connection failed. Please try again.");
      }
    }
    document.getElementById("buy-btn")?.addEventListener("click", handleBuy);
    document.getElementById("buy-btn-2")?.addEventListener("click", handleBuy);
  </script>
</Layout>
