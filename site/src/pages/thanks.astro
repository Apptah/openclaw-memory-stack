---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Thank You — OpenClaw Memory Stack">
  <style>
    .container {
      max-width: 640px;
      margin: 0 auto;
      padding: 8rem 1.5rem 4rem;
      text-align: center;
    }
    .status-icon {
      width: 64px; height: 64px;
      margin: 0 auto 2rem;
      background: rgba(0, 230, 118, 0.1);
      border: 1px solid rgba(0, 230, 118, 0.3);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.8rem;
      box-shadow: 0 0 30px rgba(0, 230, 118, 0.15);
    }
    .container h1 {
      font-size: 2rem;
      font-weight: 700;
      color: var(--fg-bright);
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
    }
    .container .sub {
      color: var(--muted);
      font-size: 1rem;
      margin-bottom: 0.5rem;
      line-height: 1.6;
    }
    .email-box {
      background: var(--surface);
      border: 1px solid var(--accent);
      border-radius: 10px;
      padding: 1.75rem;
      margin: 2rem 0;
      text-align: left;
    }
    .email-box h2 {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--accent);
      margin-bottom: 1rem;
    }
    .email-box p {
      color: var(--fg);
      font-size: 0.9rem;
      line-height: 1.6;
      margin-bottom: 0.5rem;
    }
    .email-box .hint {
      color: var(--muted);
      font-size: 0.82rem;
    }
    .steps {
      text-align: left;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 2rem;
      margin-top: 2rem;
    }
    .steps h2 {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--accent);
      margin-bottom: 1.25rem;
    }
    .step {
      display: flex;
      gap: 1rem;
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--border);
      align-items: flex-start;
    }
    .step:last-child { border-bottom: none; }
    .step-num {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--accent);
      background: var(--accent-dim);
      width: 24px; height: 24px;
      display: flex; align-items: center; justify-content: center;
      border-radius: 4px;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .step-text {
      font-size: 0.9rem;
      color: var(--fg);
      line-height: 1.5;
    }
    .bottom-link {
      margin-top: 2rem;
      font-size: 0.85rem;
    }
  </style>

  <div class="container">
    <div class="status-icon">&#x2713;</div>
    <h1>Payment received.</h1>
    <p class="sub">Your license key and download link have been sent to your email.</p>

    <div class="email-box">
      <h2>// check your inbox</h2>
      <p>Look for an email from <strong>OpenClaw Memory Stack</strong> with your license key and a download link (expires in 24 hours).</p>
      <p class="hint">Don't see it? Check your spam folder. Still nothing after a few minutes? Contact support@dragdrop26.com</p>
    </div>

    <div class="steps">
      <h2>// once you get the email</h2>
      <div class="step">
        <div class="step-num">1</div>
        <div class="step-text">Download and unzip the file</div>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <div class="step-text">Run <code>./install.sh --key=YOUR_KEY</code></div>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <div class="step-text">Restart OpenClaw: <code>openclaw gateway restart</code></div>
      </div>
      <div class="step">
        <div class="step-num">4</div>
        <div class="step-text">Done — memory works automatically in the background</div>
      </div>
    </div>

    <p class="sub" style="font-size: 0.85rem; margin-top: 1.5rem;">Need help? <a href="/manage">Manage License</a></p>

    <div class="bottom-link">
      <a href="/">&larr; Back to home</a>
    </div>
  </div>
</Layout>
